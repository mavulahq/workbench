{
  "name": "@getfluxo/fwk",
  "version": "0.1.0",
  "private": true,
  "description": "getfluxo.io Worker Kit - platform worker runtime and public status API",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "test": "jest --runInBand",
    "test:e2e": "jest --config jest.e2e.config.js --runInBand",
    "test:all": "jest --runInBand && jest --config jest.e2e.config.js --runInBand"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "^29.0.0",
    "@types/supertest": "^6.0.2",
    "jest": "^29.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": "22.22.3",
    "pnpm": "10.33.0"
  }
}
